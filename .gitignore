# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ignore all hidden files
.*

# hidden file exceptions
!.gitignore
!.biomeignore
!.dockerignore
!.github

# dependencies
/node_modules

# testing
/coverage

# next.js
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo
next-env.d.ts
